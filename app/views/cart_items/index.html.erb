<div class="p-6">
  <h1 class="text-2xl font-bold mb-4">Корзина</h1>
  <% if @cart_items.empty? %>
    <p><%= t('cart.empty') %></p>
  <% else %>
    <table class="w-full text-left border">
      <thead>
        <tr class="bg-gray-200">
          <th class="p-2">Товар</th>
          <th class="p-2">Количество</th>
          <th class="p-2">Цена</th>
          <th class="p-2">Удалить</th>
        </tr>
      </thead>
      <tbody>
        <% @cart_items.each do |item| %>
          <tr class="border-t">
            <td class="p-2"><%= item.product.name %></td>
            <td class="p-2"><%= item.quantity %></td>
            <td class="p-2"><%= number_to_currency(item.product.price * item.quantity) %></td>
            <td class="p-2">
              <%= button_to 'Удалить', cart_item_path(item), method: :delete, data: { confirm: 'Удалить из корзины?' }, class: "text-red-600" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
